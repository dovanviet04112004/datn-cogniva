# pnpm config — hoist Expo + RN packages cho Metro bundler resolve transitive deps.
#
# Metro KHÔNG follow pnpm strict symlink chain → cần hoist các package này
# tới level mà Node resolution thấy được. Chỉ affect apps/mobile (apps/web
# không có Expo/RN deps).
#
# public-hoist-pattern = symlink package match pattern vào node_modules
# của workspace root (level cao nhất Node sẽ tìm khi walk-up).
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=@react-native-*
public-hoist-pattern[]=metro*
public-hoist-pattern[]=@babel/runtime

# pnpm strict-peer-dependencies=false → bỏ qua peer warning radix-ui v1.0.x cũ
strict-peer-dependencies=false
