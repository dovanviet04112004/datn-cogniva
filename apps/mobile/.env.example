# Env vars cho Expo client (must prefix EXPO_PUBLIC_ để inject vào bundle).
# Copy thành .env.local (gitignored) khi dev.

# API base — point tới edge gateway (production) hoặc Next.js dev (local)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Optional: edge gateway URL nếu test edge path
# EXPO_PUBLIC_API_URL=http://localhost:8787

# Sentry / PostHog cho mobile (Stage 2 W3 wire)
# EXPO_PUBLIC_SENTRY_DSN=
# EXPO_PUBLIC_POSTHOG_KEY=
