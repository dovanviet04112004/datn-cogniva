{
  "expo": {
    "name": "Cogniva",
    "slug": "cogniva",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "cogniva",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cogniva.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.cogniva.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#0066FF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "72508ea4-d50b-4dd4-a7e6-155fd654b3bc"
      }
    },
    "owner": "dovanviet"
  }
}
