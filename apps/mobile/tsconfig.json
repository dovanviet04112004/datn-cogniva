// tsconfig cho @cogniva/mobile — Expo / React Native (Hermes engine).
//
// Khác apps/web:
//   - target ES2020 (Hermes hỗ trợ tới ES2020 chính thức)
//   - jsx: react-jsx (RN 0.76+ + Expo 52)
//   - moduleResolution: node (Metro bundler dùng node resolution)
//
// extends expo's preset → tự config @types/react, RN types, etc.
{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": ["node_modules"]
}
