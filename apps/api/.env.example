# apps/api — env mẫu. Cách nhanh nhất: node apps/api/scripts/setup-env.mjs
# (tự sinh .env từ apps/web/.env.local + keypair JWT).
# ⚠️ DATABASE_URL phải trỏ CÙNG DB với apps/web/.env.local (Neon — KHÔNG phải
# localhost của packages/db). Thêm ?pgbouncer=true vì Neon pooled connection
# (tương đương prepare:false của postgres.js).
PORT=4000
NODE_ENV=development

DATABASE_URL="postgresql://user:pass@host-pooler.region.aws.neon.tech/db?sslmode=require&pgbouncer=true"
# Unpooled — prisma migrate cần connection trực tiếp (không qua pgbouncer).
DIRECT_DATABASE_URL="postgresql://user:pass@host.region.aws.neon.tech/db?sslmode=require"

REDIS_URL="redis://localhost:6379"

# Cùng secret với apps/web — Wave 0/1 dual-accept verify session Better Auth cũ.
BETTER_AUTH_SECRET=""

# Keypair ES256 (PEM, escape newline bằng \n) cho JWT access token mới —
# setup-env.mjs tự sinh.
AUTH_JWT_PRIVATE_KEY=""
AUTH_JWT_PUBLIC_KEY=""

# DB docker local (đồng bộ schema với Neon — migration apply CẢ HAI):
DATABASE_URL_LOCAL="postgresql://postgres:postgres@localhost:5432/cogniva"
