model user_stats {
  user_id            String   @id
  xp                 Int      @default(0)
  current_streak     Int      @default(0)
  longest_streak     Int      @default(0)
  last_activity_date String?
  achievements       String[] @default([])
  updated_at         DateTime @default(now()) @db.Timestamp(6)
  user               user     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([xp])
}

model user_wallet {
  user_id                  String    @id
  balance_vnd              Int       @default(0)
  promo_balance_vnd        Int       @default(0)
  promo_expires_at         DateTime? @db.Timestamp(6)
  auto_topup_threshold_vnd Int?
  auto_topup_amount_vnd    Int?
  created_at               DateTime  @default(now()) @db.Timestamp(6)
  updated_at               DateTime  @default(now()) @db.Timestamp(6)
  user                     user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model user_wallet_txn {
  id                String   @id
  user_id           String
  type              String
  amount_vnd        Int
  balance_after_vnd Int
  related_id        String?
  related_type      String?
  description       String?
  created_at        DateTime @default(now()) @db.Timestamp(6)
  user              user     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, created_at(sort: Desc)], map: "user_wallet_txn_user_time_idx")
}

model verification {
  id         String   @id
  identifier String
  value      String
  expires_at DateTime @db.Timestamp(6)
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)
}

model workspace {
  id                      String                    @id
  user_id                 String
  name                    String
  description             String?
  created_at              DateTime                  @default(now()) @db.Timestamp(6)
  conversation            conversation[]
  document                document[]
  exam                    exam[]
  flashcard               flashcard[]
  library_doc_import      library_doc_import[]
  note                    note[]
  quiz                    quiz[]
  user                    user                      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "workspace_user_id_user_id_fk")
  workspace_cached_output workspace_cached_output[]

  @@index([user_id], map: "workspace_user_idx")
}

model workspace_cached_output {
  id           String                @id
  workspace_id String
  user_id      String
  kind         workspace_cached_kind
  markdown     String
  meta         Json                  @default("{}")
  generated_at DateTime              @default(now()) @db.Timestamp(6)
  user         user                  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  workspace    workspace             @relation(fields: [workspace_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([workspace_id, user_id, kind], map: "workspace_cached_uniq")
  @@index([workspace_id, user_id, kind], map: "workspace_cached_lookup_idx")
}

model password_reset_token {
  id         String    @id
  user_id    String
  token_hash String    @unique
  expires_at DateTime  @db.Timestamp(6)
  used_at    DateTime? @db.Timestamp(6)
  created_at DateTime  @default(now()) @db.Timestamp(6)
  user       user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "password_reset_token_user_idx")
}

model refresh_token {
  id          String    @id
  user_id     String
  token_hash  String    @unique
  family_id   String
  expires_at  DateTime  @db.Timestamp(6)
  revoked_at  DateTime? @db.Timestamp(6)
  replaced_by String?
  ip_address  String?
  user_agent  String?
  created_at  DateTime  @default(now()) @db.Timestamp(6)
  user        user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([family_id], map: "refresh_token_family_idx")
  @@index([user_id], map: "refresh_token_user_idx")
}

