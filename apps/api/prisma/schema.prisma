generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model account {
  id                       String    @id
  user_id                  String
  account_id               String
  provider_id              String
  access_token             String?
  refresh_token            String?
  id_token                 String?
  access_token_expires_at  DateTime? @db.Timestamp(6)
  refresh_token_expires_at DateTime? @db.Timestamp(6)
  scope                    String?
  password                 String?
  created_at               DateTime  @default(now()) @db.Timestamp(6)
  updated_at               DateTime  @default(now()) @db.Timestamp(6)
  user                     user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "account_user_id_user_id_fk")
}

model admin_audit_log {
  id          String   @id
  admin_id    String
  action      String
  target_type String
  target_id   String
  payload     Json     @default("{}")
  ip          String?  @db.Inet
  user_agent  String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  user        user     @relation(fields: [admin_id], references: [id], onUpdate: NoAction)

  @@index([action, created_at(sort: Desc)], map: "idx_audit_action")
  @@index([admin_id, created_at(sort: Desc)], map: "idx_audit_admin")
  @@index([target_type, target_id], map: "idx_audit_target")
}

model ai_usage_log {
  id         String   @id
  user_id    String?
  plan       String?
  provider   String
  model      String
  feature    String?
  tokens_in  Int      @default(0)
  tokens_out Int      @default(0)
  cost_usd   Float    @default(0) @db.Real
  latency_ms Int?
  cached     Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  user       user?    @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([provider, created_at(sort: Desc)], map: "idx_ai_usage_provider_time")
  @@index([created_at(sort: Desc)], map: "idx_ai_usage_time")
  @@index([user_id, created_at(sort: Desc)], map: "idx_ai_usage_user_time")
}

model audit_log {
  id            String   @id
  actor_id      String?
  actor_type    String
  action        String
  result        String
  resource_type String?
  resource_id   String?
  ip_address    String?
  user_agent    String?
  trace_id      String?
  metadata      Json?
  timestamp     DateTime @default(now()) @db.Timestamp(6)

  @@index([action, timestamp(sort: Desc)], map: "audit_log_action_time_idx")
  @@index([actor_id, timestamp(sort: Desc)], map: "audit_log_actor_time_idx")
  @@index([resource_type, resource_id], map: "audit_log_resource_idx")
  @@index([timestamp], map: "audit_log_time_brin_idx", type: Brin)
}

model chunk {
  id            String                 @id
  document_id   String
  content       String
  embedding     Unsupported("vector")?
  metadata      Json
  tokens        Int
  document      document               @relation(fields: [document_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "chunk_document_id_document_id_fk")
  chunk_concept chunk_concept[]
  flashcard     flashcard[]

  @@index([document_id], map: "chunk_doc_idx")
  @@index([embedding])
}

model chunk_concept {
  chunk_id   String
  concept_id String
  strength   Float   @default(1) @db.Real
  chunk      chunk   @relation(fields: [chunk_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "chunk_concept_chunk_id_chunk_id_fk")
  concept    concept @relation(fields: [concept_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "chunk_concept_concept_id_concept_id_fk")

  @@id([chunk_id, concept_id])
  @@index([concept_id], map: "chunk_concept_concept_idx")
}

model collab_doc {
  id         String   @id
  type       String
  state      String
  updated_at DateTime @default(now()) @db.Timestamp(6)
}

model concept {
  id                                                 String                 @id
  name                                               String
  description                                        String?
  domain                                             String
  embedding                                          Unsupported("vector")?
  examples                                           Json                   @default("[]")
  difficulty                                         Float?                 @db.Real
  preview_question                                   String?
  preview_answer                                     String?
  chunk_concept                                      chunk_concept[]
  concept_relation_concept_relation_from_idToconcept concept_relation[]     @relation("concept_relation_from_idToconcept")
  concept_relation_concept_relation_to_idToconcept   concept_relation[]     @relation("concept_relation_to_idToconcept")
  exam_question                                      exam_question[]
  flashcard                                          flashcard[]
  mastery                                            mastery[]
  note                                               note[]
  question                                           question[]
  study_plan_item                                    study_plan_item[]

  @@index([difficulty])
  @@index([embedding])
}

model concept_relation {
  id                                        String  @id
  from_id                                   String
  to_id                                     String
  relation_type                             String
  strength                                  Float   @default(1) @db.Real
  concept_concept_relation_from_idToconcept concept @relation("concept_relation_from_idToconcept", fields: [from_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "concept_relation_from_id_concept_id_fk")
  concept_concept_relation_to_idToconcept   concept @relation("concept_relation_to_idToconcept", fields: [to_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "concept_relation_to_id_concept_id_fk")

  @@unique([from_id, to_id, relation_type], map: "concept_relation_uniq")
}

model content_report {
  id                                    String    @id
  reporter_id                           String
  target_type                           String
  target_id                             String
  reason                                String
  status                                String    @default("PENDING")
  resolved_by                           String?
  resolved_at                           DateTime? @db.Timestamptz(6)
  resolution                            String?
  created_at                            DateTime  @default(now()) @db.Timestamptz(6)
  user_content_report_reporter_idTouser user      @relation("content_report_reporter_idTouser", fields: [reporter_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user_content_report_resolved_byTouser user?     @relation("content_report_resolved_byTouser", fields: [resolved_by], references: [id], onUpdate: NoAction)

  @@index([target_type, target_id], map: "idx_report_target")
}

model conversation {
  id           String     @id
  user_id      String
  workspace_id String?
  title        String?
  created_at   DateTime   @default(now()) @db.Timestamp(6)
  user         user       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "conversation_user_id_user_id_fk")
  workspace    workspace? @relation(fields: [workspace_id], references: [id], onUpdate: NoAction, map: "conversation_workspace_id_workspace_id_fk")
  message      message[]

  @@index([user_id, created_at], map: "conversation_user_created_idx")
}

model deletion_request {
  id            String    @id
  user_id       String
  status        String    @default("PENDING")
  reason        String?
  scheduled_for DateTime  @db.Timestamp(6)
  completed_at  DateTime? @db.Timestamp(6)
  error_message String?
  requested_at  DateTime  @default(now()) @db.Timestamp(6)

  @@index([user_id, requested_at(sort: Desc)], map: "deletion_request_user_idx")
}

model dm_message {
  id          String    @id
  thread_id   String
  author_id   String
  content     String
  reply_to_id String?
  attachments Json?
  reactions   Json?
  edited_at   DateTime? @db.Timestamp(6)
  deleted_at  DateTime? @db.Timestamp(6)
  created_at  DateTime  @default(now()) @db.Timestamp(6)
  user        user      @relation(fields: [author_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  dm_thread   dm_thread @relation(fields: [thread_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([thread_id, created_at], map: "dm_message_thread_time_idx")
}

model dm_read_state {
  user_id              String
  thread_id            String
  last_read_message_id String?
  updated_at           DateTime  @default(now()) @db.Timestamp(6)
  dm_thread            dm_thread @relation(fields: [thread_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user                 user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, thread_id])
}

model dm_thread {
  id                            String          @id
  user1_id                      String
  user2_id                      String
  created_at                    DateTime        @default(now()) @db.Timestamp(6)
  last_message_at               DateTime        @default(now()) @db.Timestamp(6)
  dm_message                    dm_message[]
  dm_read_state                 dm_read_state[]
  user_dm_thread_user1_idTouser user            @relation("dm_thread_user1_idTouser", fields: [user1_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user_dm_thread_user2_idTouser user            @relation("dm_thread_user2_idTouser", fields: [user2_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user1_id, user2_id], map: "dm_thread_users_uniq")
  @@index([user1_id, last_message_at(sort: Desc)], map: "dm_thread_user1_last_idx")
  @@index([user2_id, last_message_at(sort: Desc)], map: "dm_thread_user2_last_idx")
}

model document {
  id                 String               @id
  user_id            String
  workspace_id       String
  filename           String
  mime_type          String
  size               Int
  storage_key        String
  status             doc_status           @default(PROCESSING)
  metadata           Json                 @default("{}")
  created_at         DateTime             @default(now()) @db.Timestamp(6)
  chunk              chunk[]
  user               user                 @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "document_user_id_user_id_fk")
  workspace          workspace            @relation(fields: [workspace_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "document_workspace_id_workspace_id_fk")
  library_doc_import library_doc_import[]
  note               note[]

  @@index([user_id, workspace_id], map: "document_user_workspace_idx")
}

model exam {
  id                     String          @id
  owner_id               String
  title                  String
  description            String?
  mode                   exam_mode       @default(PRACTICE)
  status                 exam_status     @default(DRAFT)
  duration_seconds       Int?
  starts_at              DateTime?       @db.Timestamp(6)
  ends_at                DateTime?       @db.Timestamp(6)
  passing_score          Float?          @db.Real
  max_score              Float           @default(0) @db.Real
  show_results           String          @default("IMMEDIATE")
  shuffle_questions      Boolean         @default(true)
  shuffle_options        Boolean         @default(true)
  allow_review           Boolean         @default(true)
  max_attempts           Int             @default(1)
  live_code              String?         @unique
  current_question_index Int?
  min_questions          Int?            @default(10)
  max_questions          Int?            @default(30)
  target_se              Float?          @default(0.3) @db.Real
  anti_cheat             Json?           @default("{}")
  classroom_id           String?
  concept_ids            Json?
  created_at             DateTime        @default(now()) @db.Timestamp(6)
  published_at           DateTime?       @db.Timestamp(6)
  workspace_id           String?
  user                   user            @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  workspace              workspace?      @relation(fields: [workspace_id], references: [id], onUpdate: NoAction, map: "exam_workspace_id_workspace_id_fk")
  exam_attempt           exam_attempt[]
  exam_question          exam_question[]

  @@index([owner_id, status], map: "exam_owner_status_idx")
  @@index([owner_id, workspace_id], map: "exam_owner_workspace_idx")
}

model exam_attempt {
  id                   String           @id
  exam_id              String
  user_id              String
  status               attempt_status   @default(IN_PROGRESS)
  started_at           DateTime         @default(now()) @db.Timestamp(6)
  submitted_at         DateTime?        @db.Timestamp(6)
  score                Float?           @db.Real
  max_score            Float?           @db.Real
  percentage           Float?           @db.Real
  passed               Boolean?
  estimated_theta      Float?           @db.Real
  theta_se             Float?           @db.Real
  time_spent_seconds   Int?
  questions_answered   Int              @default(0)
  violations           Json?
  cheat_risk_score     Float?           @db.Real
  flagged              Boolean          @default(false)
  flag_reason          String?
  webcam_recording_url String?
  proctor_notes        String?
  ip_address           String?
  user_agent           String?
  browser_fingerprint  String?
  exam                 exam             @relation(fields: [exam_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user                 user             @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  exam_response        exam_response[]
  exam_violation       exam_violation[]

  @@index([exam_id, user_id], map: "exam_attempt_exam_user_idx")
  @@index([user_id, status], map: "exam_attempt_user_status_idx")
}

model exam_question {
  id                 String          @id
  exam_id            String
  type               String
  prompt             String
  prompt_html        String?
  attachments        Json?
  options            Json?
  correct_answer     Json?
  acceptable_answers Json?
  rubric             Json?
  test_cases         Json?
  points             Float           @default(1) @db.Real
  partial_credit     Boolean         @default(false)
  difficulty         Float           @default(0) @db.Real
  discrimination     Float           @default(1) @db.Real
  guessing           Float           @default(0) @db.Real
  concept_id         String?
  explanation        String?
  hint               String?
  time_limit_seconds Int?
  order_index        Int             @default(0)
  created_at         DateTime        @default(now()) @db.Timestamp(6)
  concept            concept?        @relation(fields: [concept_id], references: [id], onUpdate: NoAction)
  exam               exam            @relation(fields: [exam_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  exam_response      exam_response[]

  @@index([exam_id, order_index], map: "exam_question_exam_order_idx")
}

model exam_response {
  id               String        @id
  attempt_id       String
  question_id      String
  answer           Json?
  is_correct       Boolean?
  points_earned    Float         @default(0) @db.Real
  started_at       DateTime?     @db.Timestamp(6)
  submitted_at     DateTime?     @db.Timestamp(6)
  response_time_ms Int?
  rank_at_submit   Int?
  ai_grading       Json?
  manual_grading   Json?
  needs_review     Boolean       @default(false)
  reviewed_by      String?
  reviewed_at      DateTime?     @db.Timestamp(6)
  created_at       DateTime      @default(now()) @db.Timestamp(6)
  exam_attempt     exam_attempt  @relation(fields: [attempt_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  exam_question    exam_question @relation(fields: [question_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user             user?         @relation(fields: [reviewed_by], references: [id], onUpdate: NoAction)

  @@unique([attempt_id, question_id], map: "exam_response_attempt_question_idx")
}

model exam_violation {
  id           String       @id
  attempt_id   String
  type         String
  severity     String
  metadata     Json?
  timestamp    DateTime     @default(now()) @db.Timestamp(6)
  exam_attempt exam_attempt @relation(fields: [attempt_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([attempt_id], map: "exam_violation_attempt_idx")
}

model flashcard {
  id              String     @id
  user_id         String
  concept_id      String?
  front           String
  back            String
  card_type       card_type  @default(BASIC)
  source_chunk_id String?
  difficulty      Float      @default(0) @db.Real
  stability       Float      @default(0) @db.Real
  retrievability  Float      @default(0) @db.Real
  state           fsrs_state @default(NEW)
  due             DateTime   @default(now()) @db.Timestamp(6)
  last_review     DateTime?  @db.Timestamp(6)
  workspace_id    String?
  concept         concept?   @relation(fields: [concept_id], references: [id], onUpdate: NoAction, map: "flashcard_concept_id_concept_id_fk")
  chunk           chunk?     @relation(fields: [source_chunk_id], references: [id], onUpdate: NoAction, map: "flashcard_source_chunk_id_chunk_id_fk")
  user            user       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "flashcard_user_id_user_id_fk")
  workspace       workspace? @relation(fields: [workspace_id], references: [id], onUpdate: NoAction, map: "flashcard_workspace_id_workspace_id_fk")
  review          review[]

  @@index([user_id, due], map: "flashcard_user_due_idx")
  @@index([user_id, workspace_id], map: "flashcard_user_workspace_idx")
}

model jwks {
  id          String    @id
  public_key  String
  private_key String
  created_at  DateTime  @default(now()) @db.Timestamp(6)
  expires_at  DateTime? @db.Timestamp(6)

  @@index([created_at(sort: Desc)])
}

model library_course {
  id                 String              @id
  university_id      String?
  code               String?
  name               String
  slug               String
  subject_area       String?
  doc_count          Int                 @default(0)
  approved           Boolean             @default(false)
  created_by         String?
  created_at         DateTime            @default(now()) @db.Timestamp(6)
  user               user?               @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  library_university library_university? @relation(fields: [university_id], references: [id], onUpdate: NoAction)
  library_doc        library_doc[]

  @@index([subject_area], map: "library_course_subject_idx")
  @@index([university_id, doc_count(sort: Desc)], map: "library_course_university_idx")
}

model library_creator_karma {
  user_id       String    @id
  points        Int       @default(0)
  rank          Int?
  last_event_at DateTime? @db.Timestamp(6)
  updated_at    DateTime  @default(now()) @db.Timestamp(6)
  user          user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([points(sort: Desc)])
}

model library_doc {
  id                      String                    @id
  uploader_id             String
  title                   String
  description             String?
  subject_slug            String
  level                   String
  grade                   Int?
  doc_type                String                    @default("other")
  exam_type               String?
  school_year             String?
  region                  String?                   @default("national")
  language                String?                   @default("vi")
  tags                    String[]                  @default([])
  difficulty              String?
  prerequisite_atom_slugs String[]                  @default([])
  file_format             String
  file_size_bytes         Int
  file_url                String
  file_hash               String
  page_count              Int?
  preview_thumb_url       String?
  ai_summary              String?
  ai_summary_at           DateTime?                 @db.Timestamp(6)
  preview_text            String?
  title_embedding         Unsupported("vector")?
  license                 String?                   @default("CC-BY-4.0")
  status                  String?                   @default("PROCESSING")
  hidden_at               DateTime?                 @db.Timestamp(6)
  hidden_reason           String?
  view_count              Int?                      @default(0)
  download_count          Int?                      @default(0)
  workspace_import_count  Int?                      @default(0)
  rating_avg              Decimal?                  @db.Decimal(3, 2)
  rating_count            Int?                      @default(0)
  quality_score           Decimal?                  @db.Decimal(5, 2)
  quality_breakdown       Json?
  badges                  String[]                  @default([])
  is_premium              Boolean?                  @default(false)
  price_vnd               Int?
  creator_share_pct       Int?                      @default(80)
  created_at              DateTime                  @default(now()) @db.Timestamp(6)
  updated_at              DateTime                  @default(now()) @db.Timestamp(6)
  parent_remix_doc_ids    String[]                  @default([])
  remix_count             Int                       @default(0)
  course_id               String?
  university_id           String?
  course_name_cache       String?
  university_name_cache   String?
  search_vec              Unsupported("tsvector")?  @default(dbgenerated("(((((setweight(to_tsvector('simple'::regconfig, immutable_unaccent(COALESCE(title, ''::text))), 'A'::\"char\") || setweight(to_tsvector('simple'::regconfig, immutable_unaccent(COALESCE(course_name_cache, ''::text))), 'A'::\"char\")) || setweight(to_tsvector('simple'::regconfig, immutable_unaccent(COALESCE(university_name_cache, ''::text))), 'B'::\"char\")) || setweight(to_tsvector('simple'::regconfig, immutable_unaccent(COALESCE(description, ''::text))), 'B'::\"char\")) || setweight(to_tsvector('simple'::regconfig, immutable_unaccent(COALESCE(ai_summary, ''::text))), 'C'::\"char\")) || setweight(to_tsvector('simple'::regconfig, immutable_unaccent(COALESCE(preview_text, ''::text))), 'D'::\"char\"))"))
  library_course          library_course?           @relation(fields: [course_id], references: [id], onUpdate: NoAction)
  library_university      library_university?       @relation(fields: [university_id], references: [id], onUpdate: NoAction)
  user                    user                      @relation(fields: [uploader_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  library_doc_annotation  library_doc_annotation[]
  library_doc_atom        library_doc_atom[]
  library_doc_chunk       library_doc_chunk[]
  library_doc_endorsement library_doc_endorsement[]
  library_doc_import      library_doc_import[]
  library_doc_outcome     library_doc_outcome[]
  library_doc_purchase    library_doc_purchase[]
  library_doc_report      library_doc_report[]
  library_doc_review      library_doc_review[]
  library_doc_view        library_doc_view[]
  library_karma_event     library_karma_event[]

  @@index([course_id, status], map: "library_doc_course_idx")
  @@index([parent_remix_doc_ids], map: "library_doc_parent_remix_gin", type: Gin)
  @@index([quality_score(sort: Desc)], map: "library_doc_quality_idx")
  @@index([search_vec], map: "library_doc_search_vec_gin", type: Gin)
  @@index([subject_slug, grade, status], map: "library_doc_subject_grade_idx")
  @@index([subject_slug, level, status], map: "library_doc_subject_level_idx")
  @@index([tags], map: "library_doc_tags_gin", type: Gin)
  @@index([doc_type, status], map: "library_doc_type_idx")
  @@index([university_id, status], map: "library_doc_university_idx")
  @@index([uploader_id], map: "library_doc_uploader_idx")
}

model library_doc_annotation {
  id                          String                        @id
  doc_id                      String
  author_id                   String
  page_num                    Int
  note                        String
  visibility                  String                        @default("public")
  helpful_count               Int                           @default(0)
  created_at                  DateTime                      @default(now()) @db.Timestamp(6)
  updated_at                  DateTime                      @default(now()) @db.Timestamp(6)
  selected_text               String?
  selection_rect              Json?
  user                        user                          @relation(fields: [author_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  library_doc                 library_doc                   @relation(fields: [doc_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  library_doc_annotation_vote library_doc_annotation_vote[]

  @@index([author_id, created_at(sort: Desc)], map: "library_doc_annotation_author_idx")
  @@index([doc_id, page_num], map: "library_doc_annotation_doc_idx")
  @@index([doc_id, helpful_count(sort: Desc)], map: "library_doc_annotation_helpful_idx")
}

model library_doc_annotation_vote {
  id                     String                 @id
  annotation_id          String
  user_id                String
  created_at             DateTime               @default(now()) @db.Timestamp(6)
  library_doc_annotation library_doc_annotation @relation(fields: [annotation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user                   user                   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([annotation_id, user_id])
  @@index([user_id], map: "library_doc_annotation_vote_user_idx")
}

model library_doc_atom {
  id          String                 @id
  doc_id      String
  atom_text   String
  atom_slug   String
  page_nums   Int[]
  difficulty  String?
  embedding   Unsupported("vector")?
