  provider                  String                      @default("STUB")
  provider_ref              String?
  order_code                String                      @unique
  status                    String                      @default("CREATED")
  escrow_release_at         DateTime?                   @db.Timestamp(6)
  raw_response              Json?
  created_at                DateTime                    @default(now()) @db.Timestamp(6)
  captured_at               DateTime?                   @db.Timestamp(6)
  refunded_at               DateTime?                   @db.Timestamp(6)
  tutoring_class_enrollment tutoring_class_enrollment[]
  tutoring_booking          tutoring_booking            @relation(fields: [booking_id], references: [id], onUpdate: NoAction)

  @@index([booking_id], map: "tutoring_payment_booking_idx")
  @@index([status])
}

model two_factor {
  id           String  @id
  user_id      String
  secret       String
  backup_codes String
  verified     Boolean @default(true)
  user         user    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([secret], map: "idx_two_factor_secret")
  @@index([user_id], map: "idx_two_factor_user")
}

