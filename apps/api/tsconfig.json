{
  "extends": "@cogniva/tsconfig/base.json",
  "compilerOptions": {
    "module": "node16",
    "moduleResolution": "node16",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "declaration": false,
    "declarationMap": false,
    "removeComments": true,
    "sourceMap": true,
    "outDir": "./dist",
    "types": ["node", "multer"],
    "incremental": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
