{
  "name": "@cogniva/api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend NestJS — modular monolith thay dần API routes của apps/web (plan: docs/plans/nestjs-migration.md). HTTP :4000, prefix /api, Prisma + Neon, JWT auth.",
  "scripts": {
    "dev": "concurrently -k -n http,worker -c cyan,yellow \"nest start --watch\" \"node scripts/dev-worker.mjs\"",
    "dev:http": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "worker": "node dist/worker",
    "typecheck": "tsc --noEmit",
    "prisma:pull": "prisma db pull",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "clean": "rm -rf node_modules dist .turbo"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.6",
    "@ai-sdk/google": "^1.2.22",
    "@ai-sdk/groq": "^1.2.9",
    "@ai-sdk/openai": "^1.0.13",
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@cogniva/server-core": "workspace:^",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/terminus": "^11.0.0",
    "@noble/ciphers": "^2.2.0",
    "@prisma/client": "^6.1.0",
    "ai": "^4.0.18",
    "bullmq": "^5.34.0",
    "ioredis": "^5.10.1",
    "jose": "^5.9.6",
    "livekit-server-sdk": "^2.15.2",
    "mammoth": "^1.8.0",
    "nestjs-pino": "^4.1.0",
    "pdf-to-img": "^6.1.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.0",
    "ts-fsrs": "^4.6.1",
    "unpdf": "^0.12.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cogniva/tsconfig": "workspace:*",
    "@nestjs/cli": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.1.0",
    "typescript": "^5.7.2"
  }
}
