{
  "name": "@cogniva/api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend NestJS — modular monolith thay dần API routes của apps/web (plan: docs/plans/nestjs-migration.md). HTTP :4000, prefix /api, Prisma + Neon, JWT auth.",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "typecheck": "tsc --noEmit",
    "prisma:pull": "prisma db pull",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "clean": "rm -rf node_modules dist .turbo"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/terminus": "^11.0.0",
    "@noble/ciphers": "^2.2.0",
    "@prisma/client": "^6.1.0",
    "ai": "^4.0.18",
    "ioredis": "^5.10.1",
    "jose": "^5.9.6",
    "nestjs-pino": "^4.1.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cogniva/tsconfig": "workspace:*",
    "@nestjs/cli": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.1.0",
    "typescript": "^5.7.2"
  }
}
