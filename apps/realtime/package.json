{
  "name": "@cogniva/realtime",
  "version": "0.1.0",
  "private": true,
  "description": "Socket.IO gateway self-host — thay Soketi/Pusher. Auth qua Next (getServerSession), Redis adapter để scale N replica. Web emit qua @socket.io/redis-emitter.",
