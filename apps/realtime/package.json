    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@cogniva/tsconfig": "workspace:*",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
