# ============================================================================
# Mẫu biến môi trường cho Cogniva — copy file này sang .env.local rồi điền giá
# trị thật. KHÔNG commit .env.local. Secret production set qua Vercel/CI.
#
# Thứ tự điền theo phase (xem plan.md §10):
#   - Phase 0 (foundation):  App, Database, Auth (Better Auth)
#   - Phase 1 (ingest):      Storage R2, Inngest
#   - Phase 2 (RAG):         AI providers (Anthropic, OpenAI, Cohere), Redis
#   - Phase 2+ (observe):    Langfuse, Sentry, PostHog
# ============================================================================

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
# URL gốc của ứng dụng — dùng cho metadata SEO + Better Auth callback.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# Database — local Postgres 16 + pgvector qua docker-compose
# ─────────────────────────────────────────────
# Mặc định trùng với username/password trong docker-compose.yml.
# sslmode=disable vì kết nối nội bộ container, không cần TLS.
DATABASE_URL="postgresql://cogniva:cogniva@localhost:5432/cogniva?sslmode=disable"

# ─────────────────────────────────────────────
# Auth — Better Auth
# ─────────────────────────────────────────────
# Sinh secret 32 ký tự ngẫu nhiên:
#   openssl rand -base64 32
# Production BẮT BUỘC khác giá trị trong .env.local.
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Tuỳ chọn — Google OAuth provider.
# Lấy clientID/secret từ https://console.cloud.google.com/apis/credentials
# Để trống → Better Auth bỏ qua Google, chỉ còn email/password.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─────────────────────────────────────────────
# AI Providers (Phase 2 trở đi)
# ─────────────────────────────────────────────
# Claude qua console.anthropic.com — dùng Sonnet 4.6 làm default reasoner
ANTHROPIC_API_KEY=""
# OpenAI: text-embedding-3-large (3072 chiều) cho embedding chunk + Whisper STT
OPENAI_API_KEY=""
# Cohere: rerank-3 ở bước 4 của retrieval pipeline
COHERE_API_KEY=""

# ─────────────────────────────────────────────
# Storage — Cloudflare R2 (Phase 1: lưu PDF/document gốc)
# ─────────────────────────────────────────────
# R2 = S3-compatible nhưng không tính phí egress → rẻ hơn S3 nếu có client
# tải file nhiều. Tạo bucket tại https://dash.cloudflare.com/?to=/:account/r2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="cogniva-documents"
# URL public của bucket nếu mở custom domain — null thì dùng presigned URL
R2_PUBLIC_URL=""

# ─────────────────────────────────────────────
# Background jobs — Inngest (Phase 1: ingestion pipeline)
# ─────────────────────────────────────────────
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ─────────────────────────────────────────────
# Cache & rate limit — Upstash Redis (Phase 2)
# ─────────────────────────────────────────────
# Dùng REST API của Upstash để chạy được trên Edge Runtime của Vercel
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─────────────────────────────────────────────
# Observability (Phase 2+)
# ─────────────────────────────────────────────
# Langfuse: trace mọi LLM call (prompt, response, latency, cost) để debug + eval
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_BASEURL="https://cloud.langfuse.com"

# Sentry: error tracking + source map
SENTRY_DSN=""

# PostHog: product analytics + session replay (privacy-aware mode)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
