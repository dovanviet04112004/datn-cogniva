# ============================================================================
# Mẫu biến môi trường cho Cogniva — copy file này sang .env.local rồi điền giá
# trị thật. KHÔNG commit .env.local. Secret production set qua Vercel/CI.
#
# Thứ tự điền theo phase (xem docs/plans/master.md §10):
#   - Phase 0 (foundation):  App, Database, Auth (Better Auth)
#   - Phase 1 (ingest):      Storage R2, Inngest
#   - Phase 2 (RAG):         AI providers (Anthropic, OpenAI, Cohere), Redis
#   - Phase 2+ (observe):    Langfuse, Sentry, PostHog
# ============================================================================

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
# URL gốc của ứng dụng — dùng cho metadata SEO + Better Auth callback.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# Database — local Postgres 16 + pgvector qua docker-compose
# ─────────────────────────────────────────────
# Mặc định trùng với username/password trong docker-compose.yml.
# sslmode=disable vì kết nối nội bộ container, không cần TLS.
#
# Production (Neon): dùng pooler endpoint cho serverless connection share:
#   postgresql://user:pass@<id>-pooler.<region>.aws.neon.tech/cogniva?sslmode=require
#   ^ note "-pooler" suffix — Neon's built-in pgBouncer transaction mode.
# postgres.js đã config prepare=false để tương thích pooler.
DATABASE_URL="postgresql://cogniva:cogniva@localhost:5432/cogniva?sslmode=disable"

# Read replica connection (Stage 1 §15.1 W3 — optional, fallback primary nếu thiếu).
# Neon: tạo "Read Replica" trong dashboard, lấy direct endpoint (KHÔNG dùng pooler
# cho replica nếu replica có ít query — direct giảm 1 hop). Region khác primary
# để geo-affinity.
# Multi-region production: set DATABASE_REPLICA_URL_<REGION> qua Vercel region-aware.
DATABASE_REPLICA_URL=""

# Slow query monitoring thresholds (Stage 1 W3-4)
# Vượt warn → log warning + Sentry breadcrumb
# Vượt error → log error + Sentry message
DB_SLOW_WARN_MS="100"
DB_SLOW_ERROR_MS="1000"
# Set "1" để log mọi query (verbose, chỉ debug)
DB_DEBUG=""

# ─────────────────────────────────────────────
# Auth — JWT (NestJS apps/api)
# ─────────────────────────────────────────────
# Keypair ES256 + secret sinh bằng: node apps/api/scripts/setup-env.mjs

# Tuỳ chọn — Google OAuth provider.
# Lấy clientID/secret từ https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─────────────────────────────────────────────
# AI Providers (LLM) — set ít nhất 1, có thể nhiều cho fallback chain
# ─────────────────────────────────────────────
# Production path (paid):
# Claude qua console.anthropic.com — Sonnet 4.6 default reasoner ($3/$15 per 1M tok)
ANTHROPIC_API_KEY=""

# Free dev path — wire sẵn fallback (router.ts tự pick theo route):
# Groq: ~800 tok/s tốc độ cao nhất hiện tại. Free 30 req/min.
# Signup: https://console.groq.com (cần email, không cần thẻ)
GROQ_API_KEY=""

# Gemini: 1M context window, multimodal. Free 15 req/min + 1M token/day.
# Signup: https://aistudio.google.com/app/apikey (cần Google account)
GOOGLE_GENERATIVE_AI_API_KEY=""

# OpenRouter: multi-model gateway, free tier có ~50 req/day cho gpt-oss-20b:free.
# Signup: https://openrouter.ai (không cần thẻ tín dụng)
OPENROUTER_API_KEY=""

# Ép cứng provider (tuỳ chọn): anthropic | groq | google | openrouter
# Default: tự pick theo key có sẵn theo thứ tự ưu tiên trong models.ts pickChatProvider()
LLM_PROVIDER=""

# Model override (tuỳ chọn) — set khi muốn dùng model khác default
# ANTHROPIC_MODEL="claude-sonnet-4-6"
# GROQ_MODEL="llama-3.3-70b-versatile"
# GOOGLE_MODEL="gemini-2.0-flash-exp"
# OPENROUTER_MODEL="openai/gpt-oss-20b:free"

# ─────────────────────────────────────────────
# AI Providers (Embedding + Rerank + STT)
# ─────────────────────────────────────────────
# Voyage AI: voyage-3 (1024 chiều) cho embedding chunks (Phase 1+).
# Lấy free key tại https://dash.voyageai.com/api-keys (free tier 200M token).
VOYAGE_API_KEY=""
# OpenAI: Whisper STT (Phase 15 recording transcript), embedding fallback nếu thiếu Voyage
OPENAI_API_KEY=""
# Cohere: rerank-3 ở bước 4 của retrieval pipeline (Phase 3). Free trial 1000 req/month.
COHERE_API_KEY=""

# ─────────────────────────────────────────────
# Redis — Cache + Rate limit + Cost guardrail + Circuit breaker
# ─────────────────────────────────────────────
# Pick logic trong apps/web/src/lib/redis.ts (priority cao xuống thấp):
#   1. REDIS_URL → ioredis TCP (dùng Docker local hoặc DragonflyDB self-host)
#   2. UPSTASH_REDIS_REST_URL + TOKEN → @upstash/redis REST (Vercel serverless prod)
#   3. Trống cả 2 → in-memory fallback (chỉ dev, KHÔNG share giữa instance)
#
# Dev local: dùng REDIS_URL trỏ tới Docker container `cogniva-redis`
REDIS_URL="redis://localhost:6379"

# Production Vercel: dùng Upstash REST (không có TCP socket persist)
# Signup: https://console.upstash.com (free 10K commands/day)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─────────────────────────────────────────────
# Storage — Cloudflare R2 (Phase 1: lưu PDF/document gốc + Phase 15: recordings)
# ─────────────────────────────────────────────
# R2 = S3-compatible nhưng không tính phí egress → rẻ hơn S3 nếu có client
# tải file nhiều. Tạo bucket tại https://dash.cloudflare.com/?to=/:account/r2
#
# Phase 15 cần 2 bucket: `cogniva-documents` (Phase 1) + `cogniva-recordings`
# (LiveKit Egress upload MP4 trực tiếp qua S3 API). Có thể dùng cùng access
# key cho cả 2 nếu IAM policy R2 cho phép write toàn account.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="cogniva-documents"
# Bucket riêng cho recording MP4 — LiveKit Egress sẽ upload qua S3 protocol
R2_RECORDINGS_BUCKET="cogniva-recordings"
# URL public của bucket nếu mở custom domain — null thì dùng presigned URL
R2_PUBLIC_URL=""
# Storage driver cho getStorage() (workspace docs, flashcard image, group
# attachment, KYC). "r2" = đẩy thẳng R2 (production). "local" = lưu uploads/
# (dev không có R2). Bỏ trống → auto: có đủ R2 creds thì dùng r2, không thì local.
STORAGE_DRIVER="r2"

# ─────────────────────────────────────────────
# Background jobs — BullMQ (self-host, Redis)
# ─────────────────────────────────────────────
# Không cần secret riêng — BullMQ dùng REDIS_URL (xem mục Redis bên dưới).
# Worker chạy: `pnpm --filter @cogniva/web worker` (cron + event jobs). Lịch/queue
# định nghĩa ở apps/web/src/queue + src/worker. Prod: service `worker` trong
# infrastructure/docker-compose.prod.yml.

# ─────────────────────────────────────────────
# Cache & rate limit — Upstash Redis
# ─────────────────────────────────────────────
# BẮT BUỘC trong production — backed cho rate limiter, cost guardrail,
# circuit breaker (Stage 1 §15.1 W1).
#
# Dev: có thể bỏ trống → fallback in-memory (KHÔNG share giữa instance,
# warning sẽ in ra console). Production hard fail nếu thiếu.
#
# Get free tier: https://console.upstash.com (10K commands/day miễn phí).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─────────────────────────────────────────────
# AI Cost Guardrails (Stage 1 §15.1 W6, risk A2)
# ─────────────────────────────────────────────
# Override default daily quota per plan (USD). Bỏ trống = default code.
# Default: FREE $0.50, PRO $5, TEAM $50, ENTERPRISE $500.
COST_QUOTA_FREE_USD=""
COST_QUOTA_PRO_USD=""
COST_QUOTA_TEAM_USD=""
COST_QUOTA_ENTERPRISE_USD=""

# Global hourly circuit breaker (USD). Vượt → disable AI cho toàn site.
# Default $50/hour. Set thấp hơn ở dev/staging để test.
COST_GLOBAL_HOURLY_THRESHOLD_USD=""

# Log level — error | warn | info | debug. Default debug (dev) / info (prod).
LOG_LEVEL=""

# ─────────────────────────────────────────────
# Observability (Phase 2+)
# ─────────────────────────────────────────────
# Langfuse: trace mọi LLM call (prompt, response, latency, cost) để debug + eval
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_BASEURL="https://cloud.langfuse.com"

# Sentry: error tracking + source map
SENTRY_DSN=""

# PostHog: product analytics + session replay (privacy-aware mode)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ─────────────────────────────────────────────
# Phase 12 — Realtime infrastructure (Study Rooms + Live Exam V2)
# ─────────────────────────────────────────────
# Dev: chạy local stack `docker compose -f infrastructure/docker-compose.dev.yml up -d`
# rồi paste nguyên block dưới đây vào .env.local — match các value trong
# infrastructure/livekit/livekit.dev.yaml + docker-compose.dev.yml.
#
# Prod: thay bằng giá trị thật từ `bash infrastructure/scripts/generate-keys.sh`,
# update DNS theo infrastructure/scripts/dns-records.md, expose qua wss://.

# LiveKit (WebRTC SFU self-hosted)
NEXT_PUBLIC_LIVEKIT_URL="ws://localhost:7880"
LIVEKIT_API_KEY="devkey"
LIVEKIT_API_SECRET="devsecret_at_least_32_chars_long_xxx"

# Realtime (Socket.IO gateway tự host — apps/realtime). Thay Soketi/Pusher.
# Dev: chạy `pnpm --filter @cogniva/realtime dev` (nghe ws://localhost:6002).
# Prod: wss://realtime.cogniva.com (Caddy proxy → :6002).
NEXT_PUBLIC_REALTIME_URL="ws://localhost:6002"
# Gateway + emitter cần Redis chung (server emit qua @socket.io/redis-emitter).
REDIS_URL="redis://localhost:6379"

# Hocuspocus (Yjs server cho whiteboard + notes — Phase 14)
# JWT_SECRET phải match giữa Next.js (issue token) và Hocuspocus (verify).
# Dev: hardcode 32+ ký tự. Prod: generate qua infrastructure/scripts/generate-keys.sh.
NEXT_PUBLIC_HOCUSPOCUS_URL="ws://localhost:1234"
JWT_SECRET="dev-jwt-secret-at-least-32-chars-long-cogniva-xxx"

# ─────────────────────────────────────────────
# Admin Console (Phase 0)
# ─────────────────────────────────────────────
# Bootstrap allowlist — email coi như SUPER_ADMIN trước khi có cột
# user.admin_role được set. Sau khi user đã có adminRole trong DB thì env này
# không còn cần thiết (vẫn được honor làm fallback).
# Comma-separated. Fallback nếu thiếu = "dovanviet04112004@gmail.com" (xem
# apps/web/src/lib/admin/guard.ts).
# Server-side guard dùng ADMIN_EMAILS. KHÔNG dùng NEXT_PUBLIC_ADMIN_EMAILS
# nữa cho admin console — đã chuyển sang requireAdmin() server-only check.
ADMIN_EMAILS=""
NEXT_PUBLIC_ADMIN_EMAILS=""

# Payment provider switch: STUB (dev default) | VNPAY | MOMO
# STUB: auto-capture local, không gọi API ngoài, không thật tiền.
# VNPAY/MOMO: cần đủ credentials bên dưới để hoạt động; thiếu → fallback STUB.
PAYMENT_PROVIDER="STUB"

# ── VNPay (sandbox + production) ─────────────
# Đăng ký merchant tại https://sandbox.vnpayment.vn/devreg/
# Sandbox cho dev: nhận TmnCode + HashSecret + endpoint
#   Pay: https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
#   Refund: https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
# Production: https://merchant.vnpay.vn → đổi sang endpoint prod sau khi
# Vercel cấp domain HTTPS (return + IPN cần URL public, không phải localhost).
VNPAY_TMN_CODE=""
VNPAY_HASH_SECRET=""
VNPAY_PAY_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNPAY_REFUND_URL="https://sandbox.vnpayment.vn/merchant_webapi/api/transaction"
# URL FE redirect về sau khi user paid — KHÔNG localhost ở production.
# Dev expose qua ngrok/cloudflared nếu muốn test IPN thật từ sandbox.
VNPAY_RETURN_URL="http://localhost:3000/api/webhooks/vnpay"

# ── MoMo (sandbox + production) ──────────────
# Đăng ký merchant tại https://developers.momo.vn/
# Sandbox cho dev: PartnerCode + AccessKey + SecretKey
# Endpoint:
#   Create: https://test-payment.momo.vn/v2/gateway/api/create
#   Query : https://test-payment.momo.vn/v2/gateway/api/query
#   Refund: https://test-payment.momo.vn/v2/gateway/api/refund
MOMO_PARTNER_CODE=""
MOMO_ACCESS_KEY=""
MOMO_SECRET_KEY=""
MOMO_CREATE_URL="https://test-payment.momo.vn/v2/gateway/api/create"
MOMO_REFUND_URL="https://test-payment.momo.vn/v2/gateway/api/refund"
# Return URL + IPN — KHÔNG localhost ở production.
MOMO_RETURN_URL="http://localhost:3000/api/webhooks/momo"
MOMO_IPN_URL="http://localhost:3000/api/webhooks/momo"

# Phí marketplace (%) — Cogniva giữ lại khi capture payment. Default 10.
TUTORING_MARKETPLACE_FEE_PCT="10"
# Escrow window (giờ) — sau session COMPLETED, tiền giữ lại trước payout.
TUTORING_ESCROW_HOURS="168"
