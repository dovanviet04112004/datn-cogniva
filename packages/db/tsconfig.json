// tsconfig cho package @cogniva/db — chỉ chạy typecheck, không emit (drizzle-kit
// đọc trực tiếp file TS). Loại trừ drizzle.config.ts và thư mục migrations vì
// chúng không thuộc rootDir và chỉ được drizzle-kit dùng tại runtime.
{
  "extends": "@cogniva/tsconfig/base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "drizzle.config.ts", "migrations"]
}
