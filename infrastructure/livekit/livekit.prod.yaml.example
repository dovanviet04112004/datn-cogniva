# LiveKit prod config TEMPLATE — copy thành `livekit.prod.yaml` rồi điền giá trị thật.
# File `livekit.prod.yaml` đã có trong .gitignore (chứa secret).
#
# Generate API key/secret bằng `infrastructure/scripts/generate-keys.sh`.
port: 7880

rtc:
  tcp_port: 7881
  port_range_start: 50000
  port_range_end: 60000
  use_external_ip: true         # Quan trọng khi sau NAT (Hetzner Cloud OK)

redis:
  address: localhost:6379

keys:
  # Format: API_KEY: API_SECRET (secret ≥ 32 ký tự)
  YOUR_API_KEY: YOUR_API_SECRET_AT_LEAST_32_CHARS

# Webhook để Next.js sync event (participant_joined, room_finished…)
webhook:
  api_key: YOUR_API_KEY
  urls:
    - https://app.cogniva.com/api/webhooks/livekit

# TURN config — point sang coturn standalone
turn:
  enabled: true
  domain: turn.cogniva.com
  tls_port: 5349
  udp_port: 3478
  external_tls: true

# Egress (recording, Phase 15) — comment lại nếu chưa setup R2
# egress:
#   ws_url: ws://localhost:7880
#   redis:
#     address: localhost:6379
#   storage:
#     s3:
#       access_key: YOUR_R2_KEY
#       secret: YOUR_R2_SECRET
#       region: auto
#       bucket: cogniva-recordings
#       endpoint: https://YOUR_ACCOUNT.r2.cloudflarestorage.com

logging:
  level: info
  json: true
