# Cogniva infrastructure env — copy thành `.env` rồi điền giá trị thật.
# File `.env` đã có trong .gitignore.
#
# DEV (local Docker compose):
#   - Các value dưới đây MATCH `docker-compose.dev.yml` + `livekit.dev.yaml`.
#   - Có thể `cp .env.example .env` rồi `docker compose -f docker-compose.dev.yml up -d`
#     ngay — KHÔNG cần generate key, dev value đã hardcode trong compose.
#   - Block này chỉ hữu ích khi bạn override (vd đổi port để tránh conflict).
#
# PROD (Hetzner deploy):
#   - Generate secret an toàn: `bash scripts/generate-keys.sh > .env`
#   - Sau đó điền thêm DATABASE_URL + JWT_SECRET + R2_* + ALERT_WEBHOOK.

# ── LiveKit (match livekit.dev.yaml keys block) ────
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_at_least_32_chars_long_xxx

# ── Realtime (Socket.IO gateway — docker-compose.prod.yml service `realtime`) ──
# Gateway verify session qua Next nên KHÔNG có app secret riêng.
INTERNAL_API_URL=http://host.docker.internal:3000
APP_ORIGIN=https://app.cogniva.com

# ── coturn (PROD only, dev không cần TURN local) ───
TURN_SECRET=

# ── Hocuspocus (Phase 14+) ─────────────────────────
DATABASE_URL=
JWT_SECRET=

# ── Egress / R2 (Phase 15+ recording) ──────────────
R2_ACCESS_KEY=
R2_SECRET=
R2_ACCOUNT=

# ── Alerting (cron health-check.sh) ────────────────
ALERT_WEBHOOK=
