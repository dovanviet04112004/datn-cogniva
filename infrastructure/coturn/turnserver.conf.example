# coturn config TEMPLATE — copy thành `turnserver.conf` rồi điền giá trị thật.
# File `turnserver.conf` thật đã có trong .gitignore (chứa secret).
#
# Vì sao cần TURN: ~10-15% user sau symmetric NAT (corporate firewall,
# 4G hotspot, etc.) không connect được peer-to-peer → cần relay qua TURN.
# Không có TURN = họ join fail. coturn là implementation chuẩn nhất.

# ── Listening ─────────────────────────────────────────
listening-port=3478
tls-listening-port=5349
listening-ip=0.0.0.0
relay-ip=YOUR_PUBLIC_IP            # IP public của server media
external-ip=YOUR_PUBLIC_IP
min-port=49152
max-port=65535

# ── Auth (LiveKit gen credentials dynamic qua REST) ──
lt-cred-mech
realm=cogniva.com
use-auth-secret
static-auth-secret=YOUR_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS

# ── TLS (Let's Encrypt cert auto-renew qua Caddy) ────
cert=/etc/letsencrypt/live/turn.cogniva.com/fullchain.pem
pkey=/etc/letsencrypt/live/turn.cogniva.com/privkey.pem

# ── Hardening ────────────────────────────────────────
no-tcp-relay
no-stdout-log
log-file=/var/log/coturn/coturn.log
verbose

# Deny relay tới private ranges (chống abuse làm SSRF proxy)
denied-peer-ip=10.0.0.0-10.255.255.255
denied-peer-ip=172.16.0.0-172.31.255.255
denied-peer-ip=192.168.0.0-192.168.255.255
denied-peer-ip=169.254.0.0-169.254.255.255
denied-peer-ip=127.0.0.0-127.255.255.255
denied-peer-ip=::1
denied-peer-ip=fe80::-febf::
allowed-peer-ip=                   # Trống = chỉ public IPs

# ── Resource limits ──────────────────────────────────
user-quota=12                       # max 12 session per user
total-quota=1200                    # max 1200 session total
max-bps=600000                      # bandwidth cap 600kbps per session
